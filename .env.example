HOST_PORT=3000
PORT=3000
STREAMOPS_LOCAL_NO_AUTH=false
PUBLIC_BASE_URL=http://localhost:3000
DASHBOARD_BASE_URL=http://localhost:3000
OVERLAY_BASE_URL=http://localhost:3000/overlay
ALLOW_INSECURE_DEV=false
TRUST_PROXY=false
ALLOW_LEGACY_WS_QUERY_AUTH=false

TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_REDIRECT_URI=http://localhost:3000/api/twitch/auth/callback
# Twitch 채팅 명령어, 채널 포인트, 팔로우, 정기구독, 후원(Bits/Cheer)을 수신하려면 EventSub WebSocket이 켜져 있어야 합니다.
TWITCH_ENABLE_EVENTSUB=true
TWITCH_EVENTSUB_SUBSCRIPTIONS=stream.online stream.offline channel.chat.message channel.channel_points_custom_reward_redemption.add channel.follow channel.cheer channel.subscribe channel.subscription.message
TWITCH_EXTRA_SCOPES=moderator:read:followers bits:read channel:read:subscriptions
# 팔로워 목록 새로고침과 팔로우 취소 추정에는 moderator:read:followers가 필요합니다.
# Bits/Cheer 후원에는 bits:read, 정기구독에는 channel:read:subscriptions가 필요합니다.
# 설정을 바꾼 뒤에는 서버를 재시작하고 Twitch OAuth를 다시 승인해야 기존 token에 새 scope가 반영됩니다.
TWITCH_TOKEN_STORE_PATH=/app/.streamops/twitch-token.json

BRIDGE_SHARED_SECRET=replace_with_long_random_secret
BRIDGE_SHARED_SECRET_FILE=
# Riot API key는 dashboard 설정 화면에서도 등록할 수 있습니다.
# 웹에서 저장한 key는 STREAMOPS_STATE_DIR/riot-api-key.json에 저장되며 RIOT_API_KEY보다 우선 사용됩니다.
RIOT_API_KEY=your_riot_api_key
RIOT_ACCOUNT_REGION=asia
RIOT_LOL_PLATFORM=jp1
CHAT_TRANSLATION_ENABLED=false
CHAT_TRANSLATION_PROVIDER=mock
CHAT_TRANSLATION_MAX_INPUT_LENGTH=180
CHAT_TRANSLATION_MAX_PER_MINUTE=30
LOCAL_TTS_ENABLED=true
LOCAL_TTS_PROVIDER=seoya
LOCAL_TTS_BASE_URL=http://tts-engine:8787
LOCAL_TTS_SPEAKER=3
LOCAL_TTS_BROADCAST_WAIT_MS=15000
LOCAL_TTS_TIMEOUT_MS=15000
LOCAL_TTS_MAX_TEXT_LENGTH=300
LOCAL_TTS_CACHE_DIR=/app/.streamops/tts-cache
LOCAL_TTS_PUBLIC_PATH=/tts
SE0YA_TTS_BIND=127.0.0.1
SE0YA_TTS_HOST_PORT=8787
SEOYA_DEFAULT_SPEAKER_ID=3
VOICEVOX_BASE_URL=http://voicevox:50021
VOICEVOX_IMAGE=voicevox/voicevox_engine:cpu-ubuntu20.04-latest

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
# 서버 공개 배포 시 반드시 32자 이상의 긴 임의 문자열로 설정하세요.
# *_FILE을 사용하면 값을 파일에서 읽습니다. 직접 값과 *_FILE을 동시에 설정하지 마세요.
DASHBOARD_AUTH_TOKEN=
DASHBOARD_AUTH_TOKEN_FILE=
DASHBOARD_SESSION_TTL_MS=28800000
OVERLAY_ACCESS_TOKEN=
OVERLAY_ACCESS_TOKEN_FILE=

# 이 파일은 /etc/yoro/operations.env에 0600 권한으로 배치합니다.
# 실제 webhook URL이나 secret 값은 저장소에 커밋하지 않습니다.
PRODUCTION_BASE_URL=https://gg.example.com
STREAMOPS_STATE_DIR=/srv/yoro/state
STREAMOPS_BACKUP_DIR=/srv/yoro/backups
OPS_BACKUP_MAX_AGE_HOURS=26
OPS_DISK_PATH=/srv/yoro
OPS_DISK_USED_PERCENT_MAX=85
OPS_MONITOR_STATE_FILE=/var/lib/yoro-monitor/status.json
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_REPEAT_MINUTES=60
OPS_HTTP_TIMEOUT_MS=10000

NODE_ENV=development
STREAMOPS_LOCAL_NO_AUTH=false
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
DASHBOARD_BASE_URL=http://localhost:3000
OVERLAY_BASE_URL=http://localhost:3000/overlay
ALLOW_INSECURE_DEV=false
TRUST_PROXY=false
ALLOW_LEGACY_WS_QUERY_AUTH=false

# Twitch 채팅 명령어와 채널 포인트 보상을 수신하려면 EventSub WebSocket이 켜져 있어야 합니다.
TWITCH_ENABLE_EVENTSUB=true
TWITCH_EVENTSUB_SUBSCRIPTIONS=stream.online stream.offline channel.chat.message channel.channel_points_custom_reward_redemption.add
# TWITCH_EVENTSUB_SUBSCRIPTIONS=stream.online stream.offline channel.chat.message channel.channel_points_custom_reward_redemption.add channel.follow channel.cheer channel.subscribe channel.subscription.message channel.raid
TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret
TWITCH_REDIRECT_URI=http://localhost:3000/api/twitch/auth/callback
TWITCH_EXTRA_SCOPES=
# TWITCH_EXTRA_SCOPES=moderator:read:followers bits:read channel:read:subscriptions
TWITCH_TOKEN_STORE_PATH=/app/.streamops/twitch-token.json
TWITCH_USER_ACCESS_TOKEN=optional_for_local_dev_only
TWITCH_BROADCASTER_ID=your_twitch_broadcaster_id
TWITCH_BOT_USER_ID=your_twitch_bot_user_id
TWITCH_CHAT_SENDER_ID=your_twitch_chat_sender_id
TWITCH_CHAT_MODE=broadcaster
TWITCH_CHAT_THROTTLE_MS=1500
TWITCH_CHAT_COOLDOWN_MS=10000
TWITCH_CHAT_MAX_QUEUE=20
TWITCH_CHAT_MAX_LENGTH=500
TWITCH_CHAT_TEMPLATE_VALUE_MAX_LENGTH=120

BRIDGE_SHARED_SECRET=replace_with_long_random_secret
BRIDGE_SHARED_SECRET_FILE=

RIOT_API_KEY=your_riot_api_key
RIOT_ACCOUNT_REGION=asia
RIOT_LOL_PLATFORM=kr
CHAT_TRANSLATION_ENABLED=false
CHAT_TRANSLATION_PROVIDER=mock
CHAT_TRANSLATION_MAX_INPUT_LENGTH=180
CHAT_TRANSLATION_MAX_PER_MINUTE=30
LOCAL_TTS_ENABLED=true
LOCAL_TTS_PROVIDER=seoya
LOCAL_TTS_BASE_URL=http://127.0.0.1:8787
LOCAL_TTS_SPEAKER=3
LOCAL_TTS_BROADCAST_WAIT_MS=15000
LOCAL_TTS_TIMEOUT_MS=15000
LOCAL_TTS_MAX_TEXT_LENGTH=140
LOCAL_TTS_CACHE_DIR=/app/.streamops/tts-cache
LOCAL_TTS_PUBLIC_PATH=/tts
STREAMOPS_LOGS_DIR=/app/logs
STREAMOPS_STATE_DIR=/app/.streamops
STREAMOPS_REPORTS_DIR=/app/reports

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
DASHBOARD_AUTH_TOKEN=
DASHBOARD_AUTH_TOKEN_FILE=
DASHBOARD_SESSION_TTL_MS=28800000
OVERLAY_ACCESS_TOKEN=
OVERLAY_ACCESS_TOKEN_FILE=

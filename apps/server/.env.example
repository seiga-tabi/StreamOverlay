NODE_ENV=development
STREAMOPS_LOCAL_NO_AUTH=false
PORT=3000
APP_VERSION=0.1.0
GIT_SHA=unknown
BUILD_TIME=unknown
PUBLIC_BASE_URL=http://localhost:3000
DASHBOARD_BASE_URL=http://localhost:3000
OVERLAY_BASE_URL=http://localhost:3000/overlay
ALLOW_INSECURE_DEV=false
TRUST_PROXY=false
ALLOW_LEGACY_WS_QUERY_AUTH=false

# Twitch 채팅 명령어, 채널 포인트, 팔로우, 정기구독, 후원(Bits/Cheer)을 수신하려면 EventSub WebSocket이 켜져 있어야 합니다.
TWITCH_ENABLE_EVENTSUB=true
TWITCH_EVENTSUB_SUBSCRIPTIONS=stream.online stream.offline channel.chat.message channel.channel_points_custom_reward_redemption.add channel.follow channel.cheer channel.subscribe channel.subscription.message
TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret
TWITCH_REDIRECT_URI=http://localhost:3000/api/twitch/auth/callback
TWITCH_PUBLIC_REDIRECT_URI=http://localhost:3000/api/public/twitch/auth/callback
TWITCH_EXTRA_SCOPES=moderator:read:followers bits:read channel:read:subscriptions
# 팔로워 목록 새로고침과 팔로우 취소 추정에는 moderator:read:followers가 필요합니다.
# 공개 전적 페이지에서 방문자 Twitch 로그인을 사용하려면 Twitch Developer Console에 TWITCH_PUBLIC_REDIRECT_URI도 OAuth Redirect URL로 등록해야 합니다.
# Bits/Cheer 후원에는 bits:read, 정기구독에는 channel:read:subscriptions가 필요합니다.
# 설정을 바꾼 뒤에는 서버를 재시작하고 Twitch OAuth를 다시 승인해야 기존 token에 새 scope가 반영됩니다.
TWITCH_TOKEN_STORE_PATH=/app/.streamops/twitch-token.json
TWITCH_USER_ACCESS_TOKEN=optional_for_local_dev_only
TWITCH_BROADCASTER_ID=your_twitch_broadcaster_id
TWITCH_BOT_USER_ID=your_twitch_bot_user_id
TWITCH_CHAT_SENDER_ID=your_twitch_chat_sender_id
TWITCH_CHAT_MODE=broadcaster
TWITCH_CHAT_THROTTLE_MS=1500
TWITCH_CHAT_COOLDOWN_MS=10000
TWITCH_CHAT_MAX_QUEUE=20
TWITCH_CHAT_MAX_LENGTH=500
TWITCH_CHAT_TEMPLATE_VALUE_MAX_LENGTH=120
TWITCH_API_TIMEOUT_MS=10000

BRIDGE_SHARED_SECRET=replace_with_long_random_secret
BRIDGE_SHARED_SECRET_FILE=

RIOT_API_KEY=your_riot_api_key
RIOT_ACCOUNT_REGION=asia
RIOT_LOL_PLATFORM=jp1
# Personal API Key 기본 한도 보호값입니다. Production key를 쓰는 경우에만 높이세요.
RIOT_RATE_LIMIT_ENABLED=true
RIOT_RATE_LIMIT_PER_SECOND=20
RIOT_RATE_LIMIT_PER_TWO_MINUTES=100
RIOT_RATE_LIMIT_QUEUE_MAX=500
RIOT_API_TIMEOUT_MS=10000
LOG_MAX_BYTES=10485760
LOG_MAX_FILES=5
CHAT_TRANSLATION_ENABLED=false
CHAT_TRANSLATION_PROVIDER=mock
CHAT_TRANSLATION_MAX_INPUT_LENGTH=180
CHAT_TRANSLATION_MAX_PER_MINUTE=30
LOCAL_TTS_ENABLED=true
LOCAL_TTS_PROVIDER=seoya
LOCAL_TTS_BASE_URL=http://127.0.0.1:8787
LOCAL_TTS_SPEAKER=3
LOCAL_TTS_BROADCAST_WAIT_MS=15000
LOCAL_TTS_TIMEOUT_MS=15000
LOCAL_TTS_MAX_TEXT_LENGTH=140
LOCAL_TTS_CACHE_DIR=/app/.streamops/tts-cache
LOCAL_TTS_PUBLIC_PATH=/tts
STREAMOPS_LOGS_DIR=/app/logs
STREAMOPS_STATE_DIR=/app/.streamops
STREAMOPS_REPORTS_DIR=/app/reports

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
DASHBOARD_AUTH_TOKEN=
DASHBOARD_AUTH_TOKEN_FILE=
DASHBOARD_SESSION_TTL_MS=28800000
OVERLAY_ACCESS_TOKEN=
OVERLAY_ACCESS_TOKEN_FILE=

# Cloudflare Email Routing Worker가 support@yoro.gg 메일을 전달할 때 사용합니다.
SUPPORT_MAILBOX_ENABLED=false
SUPPORT_MAILBOX_ADDRESS=support@yoro.gg
SUPPORT_MAILBOX_WEBHOOK_SECRET=
SUPPORT_MAILBOX_WEBHOOK_SECRET_FILE=
SUPPORT_MAILBOX_ENCRYPTION_KEY=
SUPPORT_MAILBOX_ENCRYPTION_KEY_FILE=
SUPPORT_MAILBOX_STATE_PATH=/app/.streamops/support-mailbox.json.enc
SUPPORT_MAILBOX_RETENTION_DAYS=90
SUPPORT_MAILBOX_MAX_MESSAGES=1000

# 스트리머별 Palworld 전용 서버의 읽기 전용 상태 확인 기능입니다. OBS Bridge와 연결하지 않습니다.
PALWORLD_SERVER_STATUS_ENABLED=false
# `openssl rand -base64 32`로 별도 생성하며 다른 secret과 재사용하지 않습니다.
# 직접 값과 *_FILE을 동시에 설정할 수 없고, key를 바꾸면 기존 연결 저장소를 복호화할 수 없습니다.
PALWORLD_SERVER_CREDENTIALS_ENCRYPTION_KEY=
PALWORLD_SERVER_CREDENTIALS_ENCRYPTION_KEY_FILE=
PALWORLD_SERVER_CONNECTIONS_STATE_PATH=/app/.streamops/palworld-server-connections.json.enc
# wildcard 없이 exact origin을 필수로 등록하며, LAN/VPN 사설 주소는 CIDR도 함께 등록합니다.
# http는 명시적으로 승인한 LAN/VPN origin과 CIDR에만 허용합니다.
# 예: https://pal.example.com:8212,http://10.0.0.15:8212,10.0.0.0/24,100.64.0.0/10
PALWORLD_REST_ALLOWED_ORIGINS=
PALWORLD_REST_TIMEOUT_MS=5000
PALWORLD_REST_POLL_INTERVAL_MS=30000

# 공개 개인정보 처리방침·이용약관 운영정보. production에서는 빈 값이나 미정 문구를 허용하지 않습니다.
LEGAL_OPERATOR_NAME=
LEGAL_CONTACT_ADDRESS=
LEGAL_PRIVACY_OFFICER_NAME=
LEGAL_CONTACT_EMAIL=support@yoro.gg
LEGAL_CONTACT_PHONE=
LEGAL_EFFECTIVE_DATE=
LEGAL_MINIMUM_AGE=14
LEGAL_GOVERNING_LAW_KO=
LEGAL_GOVERNING_LAW_JA=
LEGAL_DISPUTE_VENUE_KO=
LEGAL_DISPUTE_VENUE_JA=
LEGAL_PROCESSORS_KO=
LEGAL_PROCESSORS_JA=
LEGAL_CROSS_BORDER_TRANSFER_KO=
LEGAL_CROSS_BORDER_TRANSFER_JA=

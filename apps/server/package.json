    "test:run": "node --test test/*.test.mjs",
    "test": "npm run build && npm run test:run"
  },
  "dependencies": {
    "@streamops/shared": "^0.1.0",
    "dotenv": "^16.4.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}

{
  "name": "@streamops/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:run": "node --no-warnings --import tsx --loader ../../scripts/css-module-loader.mjs --test test/*.test.ts test/*.test.tsx",
    "preview": "vite preview --port 5173"
  },
  "dependencies": {
    "@streamops/shared": "^0.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.4",
    "tsx": "^4.22.4",
    "vite": "^8.0.16"
  }
}

SERVER_WS_URL=ws://localhost:3000/bridge
# 미설정 시 PC hostname을 사용합니다. 직접 지정할 때는 각 방송 PC마다 반드시 고유하게 설정하세요.
BRIDGE_NAME=
# 등록된 스트리머의 Twitch user ID입니다. 기존 단일 Bridge 환경에서는 비워둘 수 있습니다.
BRIDGE_STREAMER_ID=
BRIDGE_SHARED_SECRET=replace_with_long_random_secret
BRIDGE_SHARED_SECRET_FILE=

OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=your_obs_websocket_password
